    "@fivenorth/loop-sdk": "^0.12.4",
    "@mysten/dapp-kit": "^1.0.4",
    "@mysten/sui": "^2.16.0",
    "@tanstack/react-query": "^5.51.0",
    "@walletconnect/ethereum-provider": "^2.23.9",
    "@walletconnect/modal": "^2.7.0",
    "framer-motion": "^11.3.19",
    "next": "14.2.5",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "viem": "^2.21.0",
    "wagmi": "^2.12.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.19",
    "postcss": "^8.4.40",
    "tailwindcss": "^3.4.7",
    "typescript": "^5.4.0",
    "vitest": "^2.1.9"

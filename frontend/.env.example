# Backend API URL
NEXT_PUBLIC_BACKEND_URL=http://localhost:4001

# Deployed MockValidatorShare contract address on Polygon Amoy
NEXT_PUBLIC_MOCK_VALIDATOR_SHARE=0x...

# --- Production Polygon ValidatorShare swap (off by default) ---
# Set to 'true' to bypass the Mock and route stake calls to real per-validator
# ValidatorShare contracts. Polygon's StakeManager deploys one ValidatorShare
# per registered validator, so this needs a JSON map below.
NEXT_PUBLIC_USE_REAL_VALIDATOR_SHARE=false
# JSON map: validator signer address (lowercase) → ValidatorShare contract.
# Find each validator's contract via:
#   StakeManager.validators(validatorId).contractAddress
# at https://amoy.polygonscan.com/address/<StakeManager>#readContract
NEXT_PUBLIC_REAL_VALIDATOR_SHARES={}

# WalletConnect v2 Project ID — required for Ledger hardware wallet support
# Get one at https://cloud.walletconnect.com (free)
# If empty, only browser-injected wallets (MetaMask etc.) are available
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# Optional: make the mock Loop connector return a hosted Canton party for real LocalNet demos.
NEXT_PUBLIC_MOCK_LOOP_PARTY_ID=Alice::1220...

# Loop SDK network: local | devnet | mainnet (default devnet)
NEXT_PUBLIC_LOOP_NETWORK=devnet

# Set to 'false' to disable the real Loop SDK and fall back to the mock provider.
NEXT_PUBLIC_LOOP_SDK_ENABLED=true

# Route Loop API calls through our backend proxy at /loop-proxy. Required
# when the Loop devnet edge blocks your origin (typical for dev IPs and
# free DDNS hostnames). Backend must have LOOP_PROXY_ENABLED=true.
NEXT_PUBLIC_LOOP_USE_BACKEND_PROXY=true

# Optional explicit overrides (take precedence over the proxy logic).
# NEXT_PUBLIC_LOOP_API_URL=https://api.your-domain.com/loop-proxy
# NEXT_PUBLIC_LOOP_WALLET_URL=https://devnet.cantonloop.com

# Live POL price falls back to this CoinGecko-derived value when the API is unreachable.
# CC isn't on a public price feed; set it manually for accurate USD displays.
NEXT_PUBLIC_CC_USD=0.16

# --- Sui Wallet (Mysten dapp-kit) ---
# Network the Sui dapp-kit provider connects to. The default mirrors the
# Sui chain adapter and the validator-scoring service (testnet).
NEXT_PUBLIC_SUI_NETWORK=testnet
NEXT_PUBLIC_SUI_RPC_URL=https://fullnode.testnet.sui.io:443

# --- Cosmos Wallet (Keplr / Leap) ---
# Per-chain config Keplr suggests on first connect. Defaults match
# Cosmos Hub theta-testnet. Override to point at a different testnet
# (e.g. provider testnet) without touching code.
NEXT_PUBLIC_COSMOS_CHAIN_ID=theta-testnet-001
NEXT_PUBLIC_COSMOS_CHAIN_NAME=Cosmos Hub Theta Testnet
NEXT_PUBLIC_COSMOS_RPC=https://rpc.sentry-01.theta-testnet.polypore.xyz
NEXT_PUBLIC_COSMOS_REST=https://rest.sentry-01.theta-testnet.polypore.xyz
NEXT_PUBLIC_COSMOS_COIN_DENOM=ATOM
NEXT_PUBLIC_COSMOS_COIN_MINIMAL_DENOM=uatom
NEXT_PUBLIC_COSMOS_COIN_DECIMALS=6
NEXT_PUBLIC_COSMOS_COIN_TYPE=118

# Optional: set to 'true' to redirect unauthenticated users to /connect.
# Default false keeps the marketing hero on / for unconnected users.
NEXT_PUBLIC_REQUIRE_CONNECT_WALL=false

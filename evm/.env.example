# Polygon Amoy RPC (public default; use your own for reliability)
AMOY_RPC_URL=https://rpc-amoy.polygon.technology

# Deployer wallet private key (get POL from https://faucets.chain.link/polygon-amoy)
# DO NOT use a wallet holding real funds.
DEPLOYER_PRIVATE_KEY=

# Optional — for contract verification on Amoy Polygonscan
POLYGONSCAN_API_KEY=

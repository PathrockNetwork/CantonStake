# --- Server ---
PORT=4001
LOG_LEVEL=info
DEMO_MODE=true

# --- Polygon Amoy ---
AMOY_RPC_URL=https://rpc-amoy.polygon.technology
MOCK_VALIDATOR_SHARE_ADDRESS=0x...

# --- Canton JSON Ledger API ---
# The CN Quickstart's app-provider participant exposes its JSON Ledger API on port 3975.
# See: https://docs.digitalasset.com/build/3.5/quickstart/configure/project-structure-overview.html
CANTON_JSON_API_URL=http://localhost:3975
CANTON_APP_PROVIDER_PARTY=CantonStake::1220...  # Fill in from `make canton-console` after make start
CANTON_AUTH_TOKEN=                                # Bearer token from Keycloak (or unused if auth disabled)
CANTON_DELEGATOR_PARTY=Alice::1220...             # Fallback party if request body omits Loop partyId
CANTON_DELEGATOR_AUTH_TOKEN=

# --- Featured App Right ---
# Contract ID of the self-featured FeaturedAppRight for our app provider party.
# On LocalNet/DevNet, self-feature via the Canton Coin wallet UI at
# http://wallet.localhost:2000 and copy the contract ID here.
FEATURED_APP_RIGHT_CID=

# --- Reward round mode ---
# Set MOCK_REWARDS=true for hackathon demos: rounds run on a deterministic
# seeded record stream so the visualiser shows believable CC accrual without
# Featured App approval. Set MOCK_REWARDS=false in production once
# FEATURED_APP_RIGHT_CID is configured.
MOCK_REWARDS=true
MOCK_REWARDS_SEED=20260505

# --- Loop SDK reverse proxy ---
# Bypasses Loop devnet's CORS allowlist by routing browser → our backend →
# devnet.cantonloop.com server-side. Disable once your real production
# origin is allowlisted by fivenorth (LOOP_PROXY_ENABLED=false).
LOOP_PROXY_ENABLED=true
LOOP_API_UPSTREAM=https://devnet.cantonloop.com

# --- PostgreSQL (Prisma) ---
DATABASE_URL=postgresql://cantonstake:cantonstake@localhost:5433/cantonstake

# --- Redis (BullMQ reward scheduler) ---
REDIS_URL=redis://localhost:6379

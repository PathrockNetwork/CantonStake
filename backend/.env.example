# --- Server ---
PORT=4000
LOG_LEVEL=info

# --- Polygon Amoy ---
AMOY_RPC_URL=https://rpc-amoy.polygon.technology
MOCK_VALIDATOR_SHARE_ADDRESS=0x...

# --- Canton JSON Ledger API ---
# The CN Quickstart's app-provider participant exposes its JSON Ledger API on port 2975.
# See: https://docs.digitalasset.com/build/3.5/quickstart/configure/project-structure-overview.html
CANTON_JSON_API_URL=http://localhost:2975
CANTON_APP_PROVIDER_PARTY=CantonStake::1220...  # Fill in from `make canton-console` after make start
CANTON_AUTH_TOKEN=                                # Bearer token from Keycloak (or unused if auth disabled)

# --- Featured App Right ---
# Contract ID of the self-featured FeaturedAppRight for our app provider party.
# On LocalNet/DevNet, self-feature via the Canton Coin wallet UI at
# http://wallet.localhost:2000 and copy the contract ID here.
FEATURED_APP_RIGHT_CID=

# --- PostgreSQL (Prisma) ---
DATABASE_URL=postgresql://cantonstake:cantonstake@localhost:5432/cantonstake

# --- Redis (BullMQ reward scheduler) ---
REDIS_URL=redis://localhost:6379

# Root .env consumed by docker-compose.yml
# Copy to .env and fill in after deploying MockValidatorShare and starting LocalNet.

# === After EVM deploy ===
MOCK_VALIDATOR_SHARE_ADDRESS=0x...
AMOY_RPC_URL=https://rpc-amoy.polygon.technology

# === After LocalNet start ===
# Get with: `make canton-console` → `participants.app_provider.parties.hosted.find(_.hint == "CantonStake")`
CANTON_JSON_API_URL=http://host.docker.internal:2975
CANTON_APP_PROVIDER_PARTY=CantonStake::1220...
CANTON_DELEGATOR_PARTY=Alice::1220...
CANTON_AUTH_TOKEN=

# === After self-featuring ===
# Contract ID shown in the CC Wallet UI after tapping "Self-feature".
FEATURED_APP_RIGHT_CID=

# === WalletConnect (Ledger support) ===
# Get a free project ID at https://cloud.walletconnect.com
NEXT_PUBLIC_BACKEND_URL=http://localhost:4000
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

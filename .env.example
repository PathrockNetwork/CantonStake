# Root .env consumed by docker-compose.yml
# Copy to .env and fill in after deploying MockValidatorShare and starting LocalNet.

# === After EVM deploy ===
MOCK_VALIDATOR_SHARE_ADDRESS=0x...
AMOY_RPC_URL=https://rpc-amoy.polygon.technology

# === After LocalNet start ===
# Get with: `make canton-console` → `participants.app_provider.parties.hosted.find(_.hint == "CantonStake")`
CANTON_JSON_API_URL=http://host.docker.internal:3975
CANTON_APP_PROVIDER_PARTY=CantonStake::1220...
CANTON_DELEGATOR_PARTY=Alice::1220...
CANTON_AUTH_TOKEN=
CANTON_DELEGATOR_AUTH_TOKEN=
DEMO_MODE=true

# === After self-featuring ===
# Contract ID shown in the CC Wallet UI after tapping "Self-feature".
FEATURED_APP_RIGHT_CID=demo-stub

# === CIP-0104 pivot ===
# CIP-0104 (live since ~Mar 2026) replaces FeaturedAppActivityMarker with
# sequencer/mediator-derived traffic attribution. Set USE_LEGACY_MARKERS=true
# only as a backwards-compat fallback during the staged rollout.
USE_LEGACY_MARKERS=false

# CID of the BeneficiarySplit contract used by RecordStake exercises.
# Created at setup time with the default 75/25 weights — capture the CID
# from the Daml Script / setup output and paste it here. When unset, the
# orchestrator silently skips RecordStake (legacy-only demo path).
BENEFICIARY_SPLIT_CID=

# === CC visualizer (§3) ===
# Scan API base URL. The reward processor polls
#   ${SCAN_API_URL}/v0/events?app_activity_records=true&round=<n>
# every round and persists the per-(party, round) records to Postgres.
# Leave unset for offline demos (paired with MOCK_REWARDS=true below).
SCAN_API_URL=

# Offline demo mode: deterministic seeded reward stream. The reward
# processor synthesises AppActivityRecords per round so the visualizer
# shows believable CC accrual without LocalNet, the Scan API, or a real
# Featured App approval. Outputs are reproducible run-to-run.
MOCK_REWARDS=false
MOCK_REWARDS_SEED=20260505

# Anthropic API for the live A1 narrator on /rewards. The narrator's
# default path is rule-based (trend-aware, deterministic, no API cost).
# Set ANTHROPIC_API_KEY to flip the narrator to live Claude Haiku output
# — useful for the demo flex but not required for any flow.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5

# === Validator quality scoring (§4) ===
# Per-chain free-source scoring for the validator picker UI / slashing
# alerts. Refreshes hourly via BullMQ; cached in Redis for the TTL.
# Set VALIDATOR_SCORING_DISABLED=true to skip the network calls (offline
# demos). Live endpoints are public, no API key required.
VALIDATOR_SCORING_DISABLED=false
VALIDATOR_SCORING_TTL_SEC=3600
VALIDATOR_SCORING_REFRESH_SEC=3600

# === Notifications (§4) ===
# Each provider is independent — set just the ones you want to use.
# Without any of them, alerts will persist as AlertEvent rows but
# delivery jobs will all return "skipped".
TELEGRAM_BOT_TOKEN=
RESEND_API_KEY=
RESEND_FROM=alerts@cantonstake.app
DISCORD_DEFAULT_WEBHOOK=

# Slashing-alert tuning
ALERTS_DISABLED=false
ALERT_SCORE_DROP_THRESHOLD=20

# === Portfolio cache + TVL snapshots (§4) ===
# Per-(chain, address) Redis snapshot of getDelegations so the
# analytics polling doesn't hammer upstream RPCs. The TVL snapshot
# cron writes one TvlSnapshot row per active user every interval.
PORTFOLIO_CACHE_TTL_SEC=60
PORTFOLIO_SNAPSHOT_INTERVAL_SEC=300
PORTFOLIO_SNAPSHOTS_DISABLED=false

# === Auto-compound keeper (§4) ===
# Disabled by default — opt in only when you have a keeper signing key
# and a real chain integration. The Polygon executor calls restake() on
# the validator share contract; all other chains are skipped (stubs).
AUTO_COMPOUND_DISABLED=true
AUTO_COMPOUND_INTERVAL_SEC=900
# Keeper EVM key. Load from a real secrets manager in production.
AUTO_COMPOUND_KEEPER_KEY=

# === Observability (§6) ===
# Sentry DSN. When unset, captureException is a no-op.
# Format: https://<publicKey>@<host>/<projectId>
SENTRY_DSN=
SENTRY_ENV=development
# Optional release tag, e.g. SHA from CI.
SENTRY_RELEASE=

# === WalletConnect (Ledger support) ===
# Get a free project ID at https://cloud.walletconnect.com
NEXT_PUBLIC_BACKEND_URL=http://localhost:4001
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=
NEXT_PUBLIC_MOCK_LOOP_PARTY_ID=Alice::1220...
